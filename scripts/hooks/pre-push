#!/bin/sh
# Pre-push hook: Run all tests before allowing a push.
# This file is committed to the repo. To install, run: scripts/setup.sh

REPO_ROOT=$(git rev-parse --show-toplevel)

echo "Running backend tests and coverage (pytest)..."
cd "$REPO_ROOT" && python -m pytest --cov=backend --cov-fail-under=55 --tb=short -q
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Backend tests or coverage FAILED. Push aborted."
    echo "   Fix the failing tests or increase coverage and try again."
    exit 1
fi

echo ""
echo "Running frontend tests and coverage (vitest)..."
cd "$REPO_ROOT/frontend" && npm run coverage
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Frontend tests or coverage FAILED. Push aborted."
    echo "   Fix the failing tests or increase coverage and try again."
    exit 1
fi

echo ""
echo "✅ All tests passed! Pushing..."
exit 0
